+
+inline tref nso_factory<tau_ba<bv, sbf_ba, qns8_ba>, bv, sbf_ba, qns8_ba>::splitter_one(
+		tref type_tree)
+{
+	using node_t = node<tau_ba<bv, sbf_ba, qns8_ba>, bv, sbf_ba, qns8_ba>;
+	using tau = tree<node_t>;
+	DBG(assert(!is_bv_type_family<node_t>(type_tree)));
+	if (is_sbf_type<node_t>(type_tree)) {
+		return tau::get(tau::bf,
+			tau::get_ba_constant(
+				sbf_ba_factory<tau_ba<bv, sbf_ba, qns8_ba>, bv, sbf_ba, qns8_ba>::splitter_one(),
+				sbf_type<node_t>()));
+	}
+	if (is_qns8_type<node_t>(type_tree)) {
+		splitter_type st;
+		return tau::get(tau::bf,
+			tau::get_ba_constant(
+				splitter(qns8_ba::one(), st),
+				qns8_type<node_t>()));
+	}
+	return tau::get(tau::bf,
+		tau::get_ba_constant(
+			tau_ba_factory<bv, sbf_ba, qns8_ba>::splitter_one(),
+			tau_type<node_t>()));
+}
+
+inline tref nso_factory<tau_ba<bv, sbf_ba, qns8_ba>, bv, sbf_ba, qns8_ba>::unpack_tau_ba(
+		const std::variant<tau_ba<bv, sbf_ba, qns8_ba>, bv, sbf_ba, qns8_ba>& v)
+{
+	if (!std::holds_alternative<tau_ba<bv, sbf_ba, qns8_ba>>(v)) return {};
+	const auto unpacked = std::get<tau_ba<bv, sbf_ba, qns8_ba>>(v);
+	return unpacked.nso_rr.main->get();
+}
+
+inline std::variant<tau_ba<bv, sbf_ba, qns8_ba>, bv, sbf_ba, qns8_ba> nso_factory<tau_ba<bv, sbf_ba, qns8_ba>,
+	bv, sbf_ba, qns8_ba>::pack_tau_ba(tref c) {
+	tau_ba<bv, sbf_ba, qns8_ba> t {c};
+	return {t};
+}
+
+inline std::variant<tau_ba<bv, sbf_ba, qns8_ba>, bv, sbf_ba, qns8_ba> nso_factory<tau_ba<bv, sbf_ba, qns8_ba>,
+	bv, sbf_ba, qns8_ba>::to_base_ba_type(tref type_tree) {
+	using node_t = node<tau_ba<bv, sbf_ba, qns8_ba>, bv, sbf_ba, qns8_ba>;
+	if (is_tau_type<node_t>(type_tree)) return { tau_ba<bv, sbf_ba, qns8_ba>() };
+	else if (is_sbf_type<node_t>(type_tree)) return { sbf_ba() };
+	else if (is_qns8_type<node_t>(type_tree)) return { qns8_ba() };
+	else {
+		DBG(assert(is_bv_type_family<node_t>(type_tree)));
+		return { bv() };
+	}
+}
