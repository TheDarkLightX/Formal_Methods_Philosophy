+inline std::string nso_factory<tau_ba<bv, sbf_ba, qns8_ba>, bv, sbf_ba, qns8_ba>::one(
+	tref type_tree)
+{
+	using node_t = node<tau_ba<bv, sbf_ba, qns8_ba>, bv, sbf_ba, qns8_ba>;
+	if (is_sbf_type<node_t>(type_tree)) {
+		return "1";
+	} else if (is_bv_type_family<node_t>(type_tree)) {
+		return make_bitvector_top_elem(get_bv_size<node_t>(type_tree)
+			).getBitVectorValue(10);
+	} else if (is_qns8_type<node_t>(type_tree)) {
+		return "255";
+	} else return "T";
