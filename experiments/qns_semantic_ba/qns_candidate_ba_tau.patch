new file mode 100644
index 00000000..fba81ae1
--- /dev/null
+++ b/src/boolean_algebras/qns_candidate_ba.h
@@ -0,0 +1,149 @@
+// To view the license please visit https://github.com/IDNI/tau-lang/blob/main/LICENSE.md
+
+#ifndef __IDNI__TAU__BOOLEAN_ALGEBRAS__QNS_CANDIDATE_BA_H__
+#define __IDNI__TAU__BOOLEAN_ALGEBRAS__QNS_CANDIDATE_BA_H__
+
+#include <algorithm>
+#include <cctype>
+#include <cstdint>
+#include <cstdlib>
+#include <optional>
+#include <ostream>
+#include <string>
+
+#include "defs.h"
+#include "splitter_types.h"
+#include "tau_tree.h"
+
+namespace idni::tau_lang {
+
+struct qns8_ba {
+	static constexpr uint8_t mask_all = 0xff;
+
+	uint8_t mask = 0;
+
+	qns8_ba() = default;
+	explicit qns8_ba(uint8_t m) : mask(m) {}
+
+	static qns8_ba zero() { return qns8_ba(0); }
+	static qns8_ba one() { return qns8_ba(mask_all); }
+
+	qns8_ba operator&(const qns8_ba& x) const { return qns8_ba(mask & x.mask); }
+	qns8_ba operator|(const qns8_ba& x) const { return qns8_ba(mask | x.mask); }
+	qns8_ba operator^(const qns8_ba& x) const { return qns8_ba(mask ^ x.mask); }
+	qns8_ba operator+(const qns8_ba& x) const { return *this ^ x; }
+	qns8_ba operator~() const { return qns8_ba(static_cast<uint8_t>(~mask)); }
+
+	auto operator<=>(const qns8_ba& x) const = default;
+
+	bool is_zero() const { return mask == 0; }
+	bool is_one() const { return mask == mask_all; }
+};
+
+inline bool qns8_env_flag_enabled() {
+	const char* flag = std::getenv("TAU_ENABLE_QNS_BA");
+	if (!flag) return false;
+	std::string value(flag);
+	std::ranges::transform(value, value.begin(),
+		[](unsigned char c) { return static_cast<char>(std::tolower(c)); });
+	return value != "0" && value != "false" && value != "no";
+}
+
+template<NodeType node>
+tref qns8_type() {
+	using tau = tree<node>;
+	tref type = tau::get(tau::type, "qns8");
+	return tau::get(tau::typed, type);
+}
+
+template<NodeType node>
+bool is_qns8_type(tref t) {
+	using tau = tree<node>;
+	return tau::get(t)[0].get_string() == "qns8";
+}
+
+inline qns8_ba normalize(const qns8_ba& f) { return qns8_ba(f.mask); }
+inline bool is_syntactic_one(const qns8_ba& f) { return f.is_one(); }
+inline bool is_syntactic_zero(const qns8_ba& f) { return f.is_zero(); }
+inline bool is_closed(const qns8_ba&) { return true; }
+
+inline uint8_t qns8_least_atom(uint8_t mask) {
+	return static_cast<uint8_t>(mask & static_cast<uint8_t>(-mask));
+}
+
+inline qns8_ba splitter(const qns8_ba& f, splitter_type&) {
+	return qns8_ba(f.mask == 0 ? 0 : qns8_least_atom(f.mask));
+}
+
+inline bool operator==(const qns8_ba& lhs, const bool& rhs) {
+	return rhs ? lhs.is_one() : lhs.is_zero();
+}
+inline bool operator==(const bool& lhs, const qns8_ba& rhs) { return rhs == lhs; }
+inline bool operator!=(const qns8_ba& lhs, const bool& rhs) { return !(lhs == rhs); }
+inline bool operator!=(const bool& lhs, const qns8_ba& rhs) { return !(rhs == lhs); }
+
+inline std::ostream& operator<<(std::ostream& os, const qns8_ba& f) {
+	return os << static_cast<unsigned>(f.mask);
+}
+
+inline tref base_ba_symbol_simplification(tref symbol, const qns8_ba&) {
+	return symbol;
+}
+inline tref base_ba_term_simplification(tref term, const qns8_ba&) {
+	return term;
+}
+
+inline std::optional<uint8_t> parse_qns8_mask(std::string src) {
+	src.erase(std::remove_if(src.begin(), src.end(),
+		[](unsigned char c) { return std::isspace(c) || c == '{' || c == '}'; }),
+		src.end());
+	if (src.empty()) return {};
+
+	int base = 10;
+	if (src.size() > 2 && src[0] == '#' &&
+		(src[1] == 'x' || src[1] == 'X')) {
+		src = src.substr(2);
+		base = 16;
+	} else if (src.size() > 2 && src[0] == '0' &&
+		(src[1] == 'x' || src[1] == 'X')) {
+		src = src.substr(2);
+		base = 16;
+	}
+
+	size_t idx = 0;
+	try {
+		unsigned long value = std::stoul(src, &idx, base);
+		if (idx != src.size() || value > qns8_ba::mask_all) return {};
+		return static_cast<uint8_t>(value);
+	} catch (...) {
+		return {};
+	}
+}
+
+template<typename... BAs>
+requires BAsPack<BAs...>
+std::optional<typename node<BAs...>::constant_with_type> parse_qns8(
+	const std::string& src)
+{
+	using node_t = node<BAs...>;
+	if (!qns8_env_flag_enabled()) {
+		LOG_ERROR << "qns8 constants require TAU_ENABLE_QNS_BA=1";
+		return {};
+	}
+	auto mask = parse_qns8_mask(src);
+	if (!mask) return {};
+	return typename node_t::constant_with_type{
+		std::variant<BAs...>{ qns8_ba(*mask) },
+		qns8_type<node_t>() };
+}
+
+} // namespace idni::tau_lang
+
+template<>
+struct std::hash<idni::tau_lang::qns8_ba> {
+	size_t operator()(const idni::tau_lang::qns8_ba& f) const noexcept {
+		return static_cast<size_t>(f.mask);
+	}
+};
+
+#endif // __IDNI__TAU__BOOLEAN_ALGEBRAS__QNS_CANDIDATE_BA_H__
